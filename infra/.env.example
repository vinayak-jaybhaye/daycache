DATABASE_URL=postgresql+asyncpg://daycache:changeme@localhost:5432/daycache

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_SECRET_KEY=changeme
API_ENV=development

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
