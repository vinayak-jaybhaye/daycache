# Root .env.example — copy to .env and fill in values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=daycache
POSTGRES_PASSWORD=changeme
POSTGRES_DB=daycache

# Full async DSN used by SQLAlchemy
DATABASE_URL=postgresql+asyncpg://daycache:changeme@localhost:5432/daycache

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
# Secret key for JWT signing — generate with: openssl rand -hex 32
API_SECRET_KEY=change-me-in-production-must-be-32-chars!
API_ENV=development
# Comma-separated list of allowed CORS origins
API_CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Web (Next.js)
# NEXT_PUBLIC_* variables are exposed to the browser
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# "local"  — write files to disk (default, no extra services needed)
# "s3"     — use S3-compatible storage (requires LocalStack or real AWS/R2)
STORAGE_BACKEND=local

# LocalStack (S3-compatible, for local dev with STORAGE_BACKEND=s3)
# Start with: cd infra && docker compose up localstack
S3_BUCKET=daycache-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_ENDPOINT_URL=http://localhost:4566

# Production (AWS S3 or Cloudflare R2) — fill in real values
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# S3_ENDPOINT_URL=          # leave empty for AWS; set for R2/MinIO

# ---------------------------------------------------------------------------
# AI Embeddings Configuration
# ---------------------------------------------------------------------------
# AI_EMBEDDING_PROVIDER:
# "mock"   — generates dummy 1536 float arrays locally (default)
# "openai" — calls OpenAI embeddings API (requires OPENAI_API_KEY)
# "gemini" — calls Gemini embeddings API (requires GEMINI_API_KEY)
# "ollama" — calls local Ollama embeddings service
AI_EMBEDDING_PROVIDER=mock

# The name of the embedding model to use (e.g. text-embedding-3-small, models/text-embedding-004, nomic-embed-text)
AI_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# AI LLM Configuration
# ---------------------------------------------------------------------------
# AI_LLM_PROVIDER:
# "mock"   — returns mock replies locally (default)
# "openai" — calls OpenAI chat completions API (requires AI_LLM_API_KEY)
# "gemini" — calls Gemini generateContent API (requires AI_LLM_API_KEY)
# "ollama" — calls local Ollama LLM service
AI_LLM_PROVIDER=mock

# The name of the LLM model to use (e.g. gpt-4o-mini, gemini-2.0-flash, llama3.2, qwen2.5)
AI_LLM_MODEL=gemini-2.0-flash

# Reflect feature specific model choices (falls back to global AI_LLM_MODEL on unsupported providers like Gemini/Ollama)
# - AI_REFLECT_STREAM_MODEL: Model for real-time natural conversational chat replies. Requires low latency.
# - AI_REFLECT_EVAL_MODEL: Lightweight model for background binary check ("YES/NO" if chat is ready to save). Run on every message; keep cheap/fast.
# - AI_REFLECT_GEN_MODEL: Smart model to synthesize full conversation and write final journal entry. Requires high prose writing quality.
AI_REFLECT_STREAM_MODEL=qwen2.5
AI_REFLECT_EVAL_MODEL=qwen2.5
AI_REFLECT_GEN_MODEL=qwen2.5

# ---------------------------------------------------------------------------
# AI Keys / Services URLs (configure as needed for chosen providers)
# ---------------------------------------------------------------------------
# API Key for OpenAI or Gemini LLM providers
AI_LLM_API_KEY=

# API Keys for OpenAI or Gemini embedding providers
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Base URL for local Ollama service (used for both LLM and embeddings if active)
# OLLAMA_BASE_URL=http://localhost:11434
